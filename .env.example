# ─────────────────────────────────────────────
#  Dark Guard AI  —  Environment Variables
# ─────────────────────────────────────────────

# ── Application ──────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

SECRET_KEY=change-me-to-a-long-random-string-in-production

API_KEY=dark-guard-dev-api-key

MCP_SECRET=dark-guard-mcp-secret

ALLOWED_ORIGINS=["*"]

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.0

# ── FastAPI Backend ───────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── MCP Server ───────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8001
MCP_TRANSPORT=http

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

REDIS_URL=redis://redis:6379/0

REDIS_SCAN_TTL=300
REDIS_MAX_CONNECTIONS=20

# ── Qdrant ────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

QDRANT_API_KEY=

QDRANT_COLLECTION_PATTERNS=pattern_examples
QDRANT_COLLECTION_HISTORY=detection_history

QDRANT_VECTOR_SIZE=1536

# ── SQLite ────────────────────────────────────
SQLITE_URL=sqlite+aiosqlite:///./dark_guard.db

# ── Playwright ───────────────────────────────
PLAYWRIGHT_BROWSER=chromium

PLAYWRIGHT_HEADLESS=true

PLAYWRIGHT_TIMEOUT=30000

PLAYWRIGHT_POOL_SIZE=5

# ── Agent Config ─────────────────────────────
AGENT_CONFIDENCE_THRESHOLD=0.70

AGENT_MAX_RETRIES=3

AGENT_RETRY_DELAY=1.0

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_SCANS_PER_MINUTE=10

RATE_LIMIT_ENABLED=true