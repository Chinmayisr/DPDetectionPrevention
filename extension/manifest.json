{
  "manifest_version": 3,

  "name": "Dark Guard AI",
  "description": "AI-powered dark pattern detection and prevention extension.",
  "version": "1.0.0",

  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "notifications",
    "scripting"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Dark Guard AI"
  },



  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]

}